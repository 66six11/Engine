root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{md,txt}]
trim_trailing_whitespace = false

[*.{yml,yaml,json}]
indent_size = 2

[CMakeLists.txt]
indent_size = 2

[*.cmake]
indent_size = 2

[*.{c,cc,cpp,cxx,h,hh,hpp,hxx,ipp,inl}]
charset = utf-8-bom

[*.ps1]
charset = utf-8

[CMakeUserPresets.json]
charset = utf-8
