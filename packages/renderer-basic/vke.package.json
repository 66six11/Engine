{
  "name": "com.vke.renderer-basic",
  "version": "0.1.0",
  "displayName": "VkEngine Basic Renderer",
  "description": "Basic renderer graph descriptions plus a Vulkan recording backend target.",
  "dependencies": [
    "com.vke.core",
    "com.vke.rendergraph",
    "com.vke.rhi-vulkan",
    "com.vke.shader-slang"
  ],
  "targets": [
    "vke-renderer-basic",
    "vke-renderer-basic-vulkan",
    "vke-renderer-basic-shaders"
  ],
  "targetDependencies": {
    "vke-renderer-basic": ["vke-core", "vke-rendergraph", "vke-shader-slang"],
    "vke-renderer-basic-vulkan": [
      "vke-renderer-basic",
      "vke-rhi-vulkan",
      "vke-rhi-vulkan-rendergraph"
    ],
    "vke-renderer-basic-shaders": [
      "vke-renderer-basic-triangle-vert",
      "vke-renderer-basic-triangle-frag",
      "vke-renderer-basic-descriptor-vert",
      "vke-renderer-basic-descriptor-frag",
      "vke-renderer-basic-mesh3d-vert",
      "vke-renderer-basic-mesh3d-frag"
    ]
  }
}
