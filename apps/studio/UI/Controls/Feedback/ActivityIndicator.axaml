<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Class="Editor.UI.Controls.Feedback.ActivityIndicator"
             x:Name="ActivityIndicatorRoot"
             mc:Ignorable="d"
             d:DesignWidth="260"
             d:DesignHeight="24">
    <UserControl.Styles>
        <Style Selector="Border.editor-activity-indicator">
            <Setter Property="MinHeight" Value="20" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="Background" Value="{DynamicResource EditorBrushStatusBarRunning}" />
            <Setter Property="BorderBrush" Value="{DynamicResource EditorBrushBorderSubtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style Selector="Ellipse.editor-activity-indicator-dot">
            <Setter Property="Width" Value="6" />
            <Setter Property="Height" Value="6" />
            <Setter Property="Fill" Value="{DynamicResource EditorBrushRunning}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style Selector="TextBlock.editor-activity-indicator-title">
            <Setter Property="FontSize" Value="{DynamicResource EditorFontSizeSmall}" />
            <Setter Property="Foreground" Value="{DynamicResource EditorBrushTextPrimary}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style Selector="TextBlock.editor-activity-indicator-message">
            <Setter Property="FontSize" Value="{DynamicResource EditorFontSizeSmall}" />
            <Setter Property="Foreground" Value="{DynamicResource EditorBrushTextMuted}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </UserControl.Styles>

    <Border Classes="editor-activity-indicator"
            IsVisible="{Binding IsActive, ElementName=ActivityIndicatorRoot}">
        <Grid ColumnDefinitions="Auto,Auto,*"
              ColumnSpacing="6"
              MaxWidth="360">
            <Ellipse Grid.Column="0"
                     Classes="editor-activity-indicator-dot" />

            <TextBlock Grid.Column="1"
                       Classes="editor-activity-indicator-title"
                       Text="{Binding Title, ElementName=ActivityIndicatorRoot}" />

            <TextBlock Grid.Column="2"
                       Classes="editor-activity-indicator-message"
                       Text="{Binding Message, ElementName=ActivityIndicatorRoot}" />
        </Grid>
    </Border>
</UserControl>
