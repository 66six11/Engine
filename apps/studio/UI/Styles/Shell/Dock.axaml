<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=netstandard"
        xmlns:dock="clr-namespace:Dock.Avalonia.Controls;assembly=Dock.Avalonia"
        xmlns:split="clr-namespace:Dock.Controls.ProportionalStackPanel;assembly=Dock.Controls.ProportionalStackPanel">
    <Styles.Resources>
        <!-- Dock theme resource overrides. Keep these mapped to editor tokens instead of cloning Dock templates. -->
        <SolidColorBrush x:Key="DockApplicationAccentBrushLow" Color="{DynamicResource EditorColorSelectionSoft}" />
        <SolidColorBrush x:Key="DockApplicationAccentBrushMed" Color="{DynamicResource EditorColorAccent}" />
        <SolidColorBrush x:Key="DockApplicationAccentBrushHigh" Color="{DynamicResource EditorColorAccentHover}" />
        <SolidColorBrush x:Key="DockApplicationAccentForegroundBrush" Color="{DynamicResource EditorColorSelectionText}" />
        <SolidColorBrush x:Key="DockApplicationAccentBrushIndicator" Color="{DynamicResource EditorColorAccent}" Opacity="0.72" />

        <SolidColorBrush x:Key="DockThemeBorderLowBrush" Color="{DynamicResource EditorColorBorderSubtle}" />
        <SolidColorBrush x:Key="DockThemeBackgroundBrush" Color="{DynamicResource EditorColorBase01}" />
        <SolidColorBrush x:Key="DockThemeAccentBrush" Color="{DynamicResource EditorColorSelectionActive}" />
        <SolidColorBrush x:Key="DockThemeForegroundBrush" Color="{DynamicResource EditorColorTextSecondary}" />
        <SolidColorBrush x:Key="DockThemeControlBackgroundBrush" Color="{DynamicResource EditorColorSurface01}" />
        <sys:Double x:Key="DockFontSizeNormal">12</sys:Double>

        <SolidColorBrush x:Key="DockSurfaceWorkbenchBrush" Color="{DynamicResource EditorColorBase00}" />
        <SolidColorBrush x:Key="DockSurfaceSidebarBrush" Color="{DynamicResource EditorColorBase01}" />
        <SolidColorBrush x:Key="DockSurfaceEditorBrush" Color="{DynamicResource EditorColorBase00}" />
        <SolidColorBrush x:Key="DockSurfacePanelBrush" Color="{DynamicResource EditorColorSurface01}" />
        <SolidColorBrush x:Key="DockSurfaceHeaderBrush" Color="{DynamicResource EditorColorSurface02}" />
        <SolidColorBrush x:Key="DockSurfaceHeaderActiveBrush" Color="{DynamicResource EditorColorSelectionInactive}" />

        <SolidColorBrush x:Key="DockBorderSubtleBrush" Color="{DynamicResource EditorColorBorderSubtle}" />
        <SolidColorBrush x:Key="DockBorderStrongBrush" Color="{DynamicResource EditorColorBorderDefault}" />
        <SolidColorBrush x:Key="DockSeparatorBrush" Color="{DynamicResource EditorColorDivider}" />
        <SolidColorBrush x:Key="DockSplitterIdleBrush" Color="{DynamicResource EditorColorDivider}" />
        <SolidColorBrush x:Key="DockSplitterHoverBrush" Color="{DynamicResource EditorColorBorderInteractive}" />
        <SolidColorBrush x:Key="DockSplitterDragBrush" Color="{DynamicResource EditorColorAccent}" />

        <SolidColorBrush x:Key="DockTabBackgroundBrush" Color="{DynamicResource EditorColorBase01}" />
        <SolidColorBrush x:Key="DockTabHoverBackgroundBrush" Color="{DynamicResource EditorColorSurface03}" />
        <SolidColorBrush x:Key="DockTabActiveBackgroundBrush" Color="{DynamicResource EditorColorSurfaceActive}" />
        <SolidColorBrush x:Key="DockTabActiveIndicatorBrush" Color="{DynamicResource EditorColorAccent}" />
        <SolidColorBrush x:Key="DockTabForegroundBrush" Color="{DynamicResource EditorColorTextSecondary}" />
        <SolidColorBrush x:Key="DockTabSelectedForegroundBrush" Color="{DynamicResource EditorColorTextPrimary}" />
        <SolidColorBrush x:Key="DockTabActiveForegroundBrush" Color="{DynamicResource EditorColorTextPrimary}" />
        <SolidColorBrush x:Key="DockTabCloseHoverBackgroundBrush" Color="{DynamicResource EditorColorError}" Opacity="0.72" />
        <SolidColorBrush x:Key="DockDocumentTabStripBackgroundBrush" Color="{DynamicResource EditorColorBase01}" />
        <SolidColorBrush x:Key="DockDocumentTabStripMaskBrush" Color="{DynamicResource EditorColorBase01}" />
        <SolidColorBrush x:Key="DockDocumentTabSelectedForegroundBrush" Color="{DynamicResource EditorColorTextPrimary}" />
        <SolidColorBrush x:Key="DockDocumentTabPointerOverForegroundBrush" Color="{DynamicResource EditorColorTextPrimary}" />
        <SolidColorBrush x:Key="DockDocumentTabCloseSelectedForegroundBrush" Color="{DynamicResource EditorColorTextPrimary}" />
        <SolidColorBrush x:Key="DockDocumentTabClosePointerOverForegroundBrush" Color="{DynamicResource EditorColorTextPrimary}" />

        <SolidColorBrush x:Key="DockTargetIndicatorBrush" Color="{DynamicResource EditorColorAccent}" Opacity="0.48" />
        <SolidColorBrush x:Key="DockChromeButtonForegroundBrush" Color="{DynamicResource EditorColorIconSecondary}" />
        <SolidColorBrush x:Key="DockToolChromeIconBrush" Color="{DynamicResource EditorColorIconSecondary}" />
        <SolidColorBrush x:Key="DockChromeButtonHoverBackgroundBrush" Color="{DynamicResource EditorColorSurface03}" />
        <SolidColorBrush x:Key="DockChromeButtonPressedBackgroundBrush" Color="{DynamicResource EditorColorSurfaceActive}" />
        <SolidColorBrush x:Key="DockChromeButtonDangerHoverBrush" Color="{DynamicResource EditorColorError}" Opacity="0.76" />
        <SolidColorBrush x:Key="DockChromeGripBrush" Color="{DynamicResource EditorColorBorderInteractive}" Opacity="0.45" />

        <SolidColorBrush x:Key="DockSelectorOverlayBackdropBrush" Color="{DynamicResource EditorColorShadow}" Opacity="0.58" />
        <SolidColorBrush x:Key="DockDocumentContentBorderBrush" Color="{DynamicResource EditorColorBorderSubtle}" />

        <sys:Double x:Key="DockCornerRadiusSmall">3</sys:Double>
        <sys:Double x:Key="DockHeaderHeight">24</sys:Double>
        <sys:Double x:Key="DockTabHeight">24</sys:Double>
        <sys:Double x:Key="DockTabHorizontalPadding">8</sys:Double>
        <sys:Double x:Key="DockIconSizeSmall">12</sys:Double>
        <sys:Double x:Key="DockIconSizeNormal">14</sys:Double>

        <sys:Double x:Key="DockTabItemMinHeight">24</sys:Double>
        <sys:Double x:Key="DockDocumentTabItemMinHeight">24</sys:Double>
        <sys:Double x:Key="DockDocumentTabItemMinWidth">88</sys:Double>
        <sys:Double x:Key="DockToolTabItemMinHeight">24</sys:Double>
        <sys:Double x:Key="DockDocumentTabStripMinHeight">25</sys:Double>
        <sys:Double x:Key="DockDocumentTabStripLeadingSpacerWidth">0</sys:Double>
        <sys:Double x:Key="DockDocumentTabItemSeparatorOpacity">1</sys:Double>
        <Thickness x:Key="DockDocumentTabItemMargin">0</Thickness>
        <Thickness x:Key="DockDocumentTabItemPadding">9,0,7,0</Thickness>
        <CornerRadius x:Key="DockDocumentTabItemCornerRadius">3,3,0,0</CornerRadius>
        <CornerRadius x:Key="DockDocumentTabCreateButtonCornerRadius">3</CornerRadius>
        <Thickness x:Key="DockToolTabItemPadding">8,0,8,0</Thickness>
        <Thickness x:Key="DockToolTabItemSelectedPadding">8,1,8,0</Thickness>

        <sys:Double x:Key="DockCreateButtonWidth">24</sys:Double>
        <sys:Double x:Key="DockCreateButtonHeight">22</sys:Double>
        <sys:Double x:Key="DockCloseButtonSize">16</sys:Double>
        <sys:Double x:Key="DockChromeButtonWidth">18</sys:Double>
        <sys:Double x:Key="DockChromeButtonHeight">16</sys:Double>
        <Thickness x:Key="DockChromeButtonPadding">2</Thickness>
        <Thickness x:Key="DockChromeButtonMargin">2,0,0,0</Thickness>
        <Thickness x:Key="DockHeaderContentPadding">2,0</Thickness>
        <Thickness x:Key="DockModifiedIndicatorMargin">0,0,3,0</Thickness>
        <sys:Double x:Key="DockTabContentSpacing">4</sys:Double>
        <sys:Double x:Key="DockDocumentTabHeaderContentSpacing">4</sys:Double>
        <Thickness x:Key="DockTabContentMargin">2</Thickness>
        <Thickness x:Key="DockCreateButtonIconMargin">5</Thickness>
        <Thickness x:Key="DockDocumentTabStripHorizontalCreateButtonMargin">2,1,4,1</Thickness>
        <Thickness x:Key="DockDocumentTabStripHorizontalScrollViewerMargin">0</Thickness>
        <Thickness x:Key="DockDocumentTabStripHorizontalScrollViewerPadding">0</Thickness>
        <Thickness x:Key="DockToolChromeHeaderMargin">8,0,6,0</Thickness>
        <Thickness x:Key="DockToolChromeTitleMargin">0,4,8,4</Thickness>
        <Thickness x:Key="DockToolChromeMenuIconMargin">2</Thickness>
        <sys:Double x:Key="DockToolChromeDividerThickness">1</sys:Double>
        <sys:Double x:Key="DockChromeGripHeight">5</sys:Double>
        <Thickness x:Key="DockChromeGripMargin">0,0,4,0</Thickness>
        <Thickness x:Key="DockDocumentContentBorderThickness">1,1,1,1</Thickness>

        <sys:Double x:Key="DockTargetSelectorSize">42</sys:Double>
        <sys:Double x:Key="DockTargetSelectorGridMaxSize">128</sys:Double>
        <CornerRadius x:Key="DockSelectorOverlayCornerRadius">6</CornerRadius>
        <Thickness x:Key="DockSelectorOverlayPadding">12</Thickness>
        <sys:Double x:Key="DockSelectorOverlayMinWidth">280</sys:Double>
        <sys:Double x:Key="DockSelectorOverlayMaxWidth">520</sys:Double>
        <sys:Double x:Key="DockSelectorOverlaySpacing">8</sys:Double>
        <sys:Double x:Key="DockSelectorOverlayListMinHeight">120</sys:Double>
        <sys:Double x:Key="DockSelectorOverlayListMaxHeight">320</sys:Double>
        <Thickness x:Key="DockSelectorOverlayItemPadding">6,4</Thickness>
        <CornerRadius x:Key="DockSelectorOverlayItemCornerRadius">4</CornerRadius>
        <sys:Double x:Key="DockSelectorOverlayBadgeSpacing">4</sys:Double>
        <Thickness x:Key="DockSelectorOverlayBadgeMargin">8,0,0,0</Thickness>
        <CornerRadius x:Key="DockSelectorOverlayBadgeCornerRadius">3</CornerRadius>
        <Thickness x:Key="DockSelectorOverlayBadgePadding">4,1</Thickness>
        <sys:Double x:Key="DockSelectorOverlayBadgeFontSize">10</sys:Double>

        <CornerRadius x:Key="DockDragPreviewCornerRadius">4</CornerRadius>
        <Thickness x:Key="DockDragPreviewHeaderPadding">6,4</Thickness>
        <sys:Double x:Key="DockDragPreviewHeaderSpacing">6</sys:Double>
        <sys:Double x:Key="DockDragPreviewStatusSpacing">4</sys:Double>
        <sys:Double x:Key="DockDragPreviewStatusIconSize">10</sys:Double>
        <sys:Double x:Key="DockDragPreviewFontSize">10</sys:Double>
    </Styles.Resources>

    <Style Selector="Grid.owned-dock-root">
        <Setter Property="Background" Value="{DynamicResource EditorBrushBase00}" />
    </Style>

    <Style Selector="UserControl.owned-dock-pane-host">
        <Setter Property="MinWidth" Value="160" />
        <Setter Property="MinHeight" Value="120" />
    </Style>

    <Style Selector="Border.owned-dock-pane">
        <Setter Property="Background" Value="{DynamicResource EditorBrushSurface01}" />
        <Setter Property="BorderBrush" Value="{DynamicResource EditorBrushBorderSubtle}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="Grid.owned-dock-pane-titlebar">
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="Background" Value="{DynamicResource EditorBrushSurface02}" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="ClipToBounds" Value="True" />
    </Style>

    <Style Selector="Grid.owned-dock-pane-titlebar > StackPanel">
        <Setter Property="Margin" Value="8,0,0,0" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBlock.owned-dock-pane-title">
        <Setter Property="Foreground" Value="{DynamicResource EditorBrushTextPrimary}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBlock.owned-dock-pane-role">
        <Setter Property="Foreground" Value="{DynamicResource EditorBrushTextMuted}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="Border.owned-dock-pane-count">
        <Setter Property="MinWidth" Value="20" />
        <Setter Property="Height" Value="18" />
        <Setter Property="Margin" Value="0,0,8,0" />
        <Setter Property="Padding" Value="5,0" />
        <Setter Property="CornerRadius" Value="3" />
        <Setter Property="Background" Value="{DynamicResource EditorBrushInputBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource EditorBrushBorderSubtle}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="Border.owned-dock-pane-count TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource EditorBrushTextSecondary}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="ItemsControl.owned-dock-tabs">
        <Setter Property="MinHeight" Value="42" />
        <Setter Property="Background" Value="{DynamicResource EditorBrushBase01}" />
        <Setter Property="BorderBrush" Value="{DynamicResource EditorBrushDivider}" />
        <Setter Property="BorderThickness" Value="0,1,0,1" />
    </Style>

    <Style Selector="Border.owned-dock-tab">
        <Setter Property="MinWidth" Value="132" />
        <Setter Property="MaxWidth" Value="240" />
        <Setter Property="Height" Value="42" />
        <Setter Property="Padding" Value="8,5" />
        <Setter Property="Background" Value="{DynamicResource EditorBrushBase01}" />
        <Setter Property="BorderBrush" Value="{DynamicResource EditorBrushDivider}" />
        <Setter Property="BorderThickness" Value="0,0,1,0" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style Selector="Border.owned-dock-tab:pointerover">
        <Setter Property="Background" Value="{DynamicResource EditorBrushSurface03}" />
    </Style>

    <Style Selector="Border.owned-dock-tab.active">
        <Setter Property="Background" Value="{DynamicResource EditorBrushSurfaceActive}" />
        <Setter Property="BorderBrush" Value="{DynamicResource EditorBrushAccent}" />
        <Setter Property="BorderThickness" Value="0,2,1,0" />
    </Style>

    <Style Selector="Border.owned-dock-tab-tag">
        <Setter Property="MinWidth" Value="30" />
        <Setter Property="Height" Value="16" />
        <Setter Property="Padding" Value="4,0" />
        <Setter Property="CornerRadius" Value="3" />
        <Setter Property="Background" Value="{DynamicResource EditorBrushSelectionSoft}" />
        <Setter Property="VerticalAlignment" Value="Top" />
    </Style>

    <Style Selector="Border.owned-dock-tab-tag TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource EditorBrushAccentHover}" />
        <Setter Property="FontSize" Value="9" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="StackPanel.owned-dock-tab-title-stack">
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBlock.owned-dock-tab-title">
        <Setter Property="Foreground" Value="{DynamicResource EditorBrushTextPrimary}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style Selector="TextBlock.owned-dock-tab-detail">
        <Setter Property="Foreground" Value="{DynamicResource EditorBrushTextMuted}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style Selector="Border.owned-dock-tab-status">
        <Setter Property="MinWidth" Value="24" />
        <Setter Property="Height" Value="16" />
        <Setter Property="Padding" Value="4,0" />
        <Setter Property="CornerRadius" Value="3" />
        <Setter Property="Background" Value="{DynamicResource EditorBrushInputBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource EditorBrushBorderSubtle}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="VerticalAlignment" Value="Top" />
    </Style>

    <Style Selector="Border.owned-dock-tab-status TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource EditorBrushTextSecondary}" />
        <Setter Property="FontSize" Value="9" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="Border.owned-dock-content">
        <Setter Property="Background" Value="{DynamicResource EditorBrushBase00}" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style Selector="GridSplitter.owned-dock-splitter">
        <Setter Property="Background" Value="{DynamicResource EditorBrushDivider}" />
    </Style>

    <Style Selector="GridSplitter.owned-dock-splitter:pointerover">
        <Setter Property="Background" Value="{DynamicResource EditorBrushBorderInteractive}" />
    </Style>

    <Style Selector="GridSplitter.owned-dock-splitter:pressed">
        <Setter Property="Background" Value="{DynamicResource EditorBrushAccent}" />
    </Style>

    <Style Selector="GridSplitter.owned-dock-splitter.vertical">
        <Setter Property="Width" Value="6" />
    </Style>

    <Style Selector="GridSplitter.owned-dock-splitter.horizontal">
        <Setter Property="Height" Value="6" />
    </Style>

    <Style Selector="Border.owned-dock-drop-preview">
        <Setter Property="Background" Value="{DynamicResource EditorBrushDropPreview}" />
        <Setter Property="BorderBrush" Value="{DynamicResource EditorBrushAccent}" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="CornerRadius" Value="4" />
    </Style>

    <Style Selector="Border.owned-dock-drop-label">
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Background" Value="{DynamicResource EditorBrushSurfaceOverlay}" />
        <Setter Property="BorderBrush" Value="{DynamicResource EditorBrushBorderInteractive}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="Border.owned-dock-drop-label TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource EditorBrushTextPrimary}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Border.owned-dock-drag-adorner">
        <Setter Property="Width" Value="220" />
        <Setter Property="Padding" Value="9,7" />
        <Setter Property="Background" Value="{DynamicResource EditorBrushSurfaceOverlay}" />
        <Setter Property="BorderBrush" Value="{DynamicResource EditorBrushBorderInteractive}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Opacity" Value="0.96" />
    </Style>

    <Style Selector="Border.owned-dock-drag-tag">
        <Setter Property="MinWidth" Value="36" />
        <Setter Property="Height" Value="18" />
        <Setter Property="Padding" Value="5,0" />
        <Setter Property="CornerRadius" Value="3" />
        <Setter Property="Background" Value="{DynamicResource EditorBrushSelectionActive}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="Border.owned-dock-drag-tag TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource EditorBrushSelectionText}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBlock.owned-dock-drag-title">
        <Setter Property="Foreground" Value="{DynamicResource EditorBrushTextPrimary}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style Selector="TextBlock.owned-dock-drag-subtitle">
        <Setter Property="Foreground" Value="{DynamicResource EditorBrushTextMuted}" />
        <Setter Property="FontSize" Value="10" />
    </Style>

    <Style Selector="dock|DockControl.editor-dock">
        <Setter Property="Background" Value="{DynamicResource DockSurfaceWorkbenchBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource DockTabForegroundBrush}" />
        <Setter Property="FontSize" Value="{DynamicResource DockFontSizeNormal}" />
    </Style>

    <Style Selector="dock|DockControl.editor-dock TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource DockTabForegroundBrush}" />
    </Style>

    <Style Selector="dock|DockControl.editor-dock dock|ToolDockControl">
        <Setter Property="Background" Value="{DynamicResource DockSurfacePanelBrush}" />
    </Style>

    <Style Selector="dock|DockControl.editor-dock dock|ToolChromeControl">
        <Setter Property="Background" Value="{DynamicResource DockSurfacePanelBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource DockBorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="dock|DockControl.editor-dock dock|ToolChromeControl:active">
        <Setter Property="BorderBrush" Value="{DynamicResource DockBorderStrongBrush}" />
    </Style>

    <Style Selector="dock|DockControl.editor-dock dock|ToolChromeControl /template/ Grid#PART_Grip">
        <Setter Property="Background" Value="{DynamicResource DockSurfaceHeaderBrush}" />
    </Style>

    <Style Selector="dock|DockControl.editor-dock dock|ToolChromeControl:active /template/ Grid#PART_Grip">
        <Setter Property="Background" Value="{DynamicResource DockSurfaceHeaderActiveBrush}" />
    </Style>

    <Style Selector="dock|DockControl.editor-dock dock|ToolChromeControl /template/ TextBlock#PART_Title">
        <Setter Property="Foreground" Value="{DynamicResource EditorBrushTextSecondary}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="dock|DockControl.editor-dock dock|ToolChromeControl:active /template/ TextBlock#PART_Title">
        <Setter Property="Foreground" Value="{DynamicResource EditorBrushTextPrimary}" />
    </Style>

    <Style Selector="dock|DockControl.editor-dock dock|ToolChromeControl /template/ Path">
        <Setter Property="Fill" Value="{DynamicResource DockChromeButtonForegroundBrush}" />
    </Style>

    <Style Selector="dock|DockControl.editor-dock dock|ToolChromeControl:active /template/ Path">
        <Setter Property="Fill" Value="{DynamicResource EditorBrushIconPrimary}" />
    </Style>

    <Style Selector="dock|DockControl.editor-dock dock|DocumentTabStrip">
        <Setter Property="Background" Value="{DynamicResource DockDocumentTabStripBackgroundBrush}" />
    </Style>

    <Style Selector="dock|DockControl.editor-dock dock|DocumentTabStripItem">
        <Setter Property="BorderBrush" Value="{DynamicResource DockSeparatorBrush}" />
    </Style>

    <Style Selector="dock|DockControl.editor-dock dock|DocumentTabStripItem:pointerover">
        <Setter Property="Foreground" Value="{DynamicResource DockDocumentTabPointerOverForegroundBrush}" />
    </Style>

    <Style Selector="dock|DockControl.editor-dock dock|DocumentTabStripItem:active:selected">
        <Setter Property="BorderBrush" Value="{DynamicResource DockTabActiveIndicatorBrush}" />
        <Setter Property="BorderThickness" Value="0,2,1,0" />
    </Style>

    <Style Selector="dock|DockControl.editor-dock dock|ToolTabStrip">
        <Setter Property="Background" Value="{DynamicResource DockTabBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource DockSeparatorBrush}" />
        <Setter Property="BorderThickness" Value="0,1,0,0" />
    </Style>

    <Style Selector="dock|DockControl.editor-dock dock|ToolTabStripItem">
        <Setter Property="Foreground" Value="{DynamicResource DockTabForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource DockSeparatorBrush}" />
    </Style>

    <Style Selector="dock|DockControl.editor-dock dock|ToolTabStripItem:selected">
        <Setter Property="Foreground" Value="{DynamicResource DockTabSelectedForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource DockTabActiveIndicatorBrush}" />
    </Style>

    <Style Selector="split|ProportionalStackPanelSplitter">
        <Setter Property="Background" Value="{DynamicResource DockSplitterIdleBrush}" />
        <Setter Property="Thickness" Value="5" />
    </Style>

    <Style Selector="split|ProportionalStackPanelSplitter:pointerover">
        <Setter Property="Background" Value="{DynamicResource DockSplitterHoverBrush}" />
    </Style>

    <Style Selector="split|ProportionalStackPanelSplitter:pressed">
        <Setter Property="Background" Value="{DynamicResource DockSplitterDragBrush}" />
    </Style>

    <Style Selector="dock|DragPreviewControl">
        <Setter Property="Opacity" Value="0.94" />
    </Style>

    <Style Selector="dock|DockSelectorOverlay TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource EditorBrushTextPrimary}" />
    </Style>

    <Style Selector="dock|HostWindow">
        <Setter Property="Background" Value="{DynamicResource DockSurfaceEditorBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource DockTabForegroundBrush}" />
    </Style>
</Styles>
