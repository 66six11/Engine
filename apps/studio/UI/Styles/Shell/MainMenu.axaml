<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Design.PreviewWith>
        <Border Padding="16" Background="#15171C">
            <Menu Classes="editor-main-menu">
                <MenuItem Header="File" Classes="editor-menu-item">
                    <MenuItem Header="New" Classes="editor-menu-item" />
                    <MenuItem Header="Save" Classes="editor-menu-item" IsEnabled="False" />
                    <Separator Classes="editor-menu-separator" />
                    <MenuItem Header="Exit" Classes="editor-menu-item" />
                </MenuItem>
                <MenuItem Header="Window" Classes="editor-menu-item">
                    <MenuItem Header="Panels" Classes="editor-menu-item">
                        <MenuItem Header="Scene View" Classes="editor-menu-item" />
                    </MenuItem>
                </MenuItem>
            </Menu>
        </Border>
    </Design.PreviewWith>

    <Style Selector="Menu.editor-main-menu">
        <Setter Property="Height" Value="28" />
        <Setter Property="Padding" Value="4,0" />
        <Setter Property="Background" Value="#20232A" />
        <Setter Property="Foreground" Value="#D8DCE5" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="MenuItem.editor-menu-item">
        <Setter Property="MinHeight" Value="26" />
        <Setter Property="Padding" Value="10,0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#D8DCE5" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style Selector="MenuItem.editor-menu-item:pointerover">
        <Setter Property="Background" Value="#2B3039" />
        <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>

    <Style Selector="MenuItem.editor-menu-item:pressed">
        <Setter Property="Background" Value="#323846" />
        <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>

    <Style Selector="MenuItem.editor-menu-item:focus">
        <Setter Property="Background" Value="#2B3039" />
        <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>

    <Style Selector="MenuItem.editor-menu-item:disabled">
        <Setter Property="Foreground" Value="#6F7480" />
    </Style>

    <Style Selector="Separator.editor-menu-separator">
        <Setter Property="Margin" Value="6,4" />
        <Setter Property="Background" Value="#3A3F4A" />
    </Style>
</Styles>
