<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Editor.Shell.ViewModels"
             xmlns:views="using:Editor.Shell.Views"
             x:Class="Editor.Shell.Views.EditorDockWindowView"
             x:DataType="vm:EditorDockWindowViewModel">
    <Border Classes.active-window="{Binding IsActiveWindow}"
            Classes="owned-dock-window">
        <Grid RowDefinitions="Auto,*">
            <views:EditorDockTabStripView Grid.Row="0"
                                          PointerPressed="OnTabPointerPressed" />

            <Border Grid.Row="1"
                    Classes.drag-source-window="{Binding IsDragSourceWindow}"
                    Classes="owned-dock-content">
                <ContentControl Content="{Binding ActiveTab.Content}" />
            </Border>
        </Grid>
    </Border>
</UserControl>
