<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Editor.Shell.ViewModels"
             xmlns:views="using:Editor.Shell.Views"
             x:Class="Editor.Shell.Views.EditorDockPaneNodeView"
             x:DataType="vm:EditorDockPaneNodeViewModel">
    <views:EditorDockPaneView Classes="owned-dock-pane-host"
                              DataContext="{Binding Pane}" />
</UserControl>
