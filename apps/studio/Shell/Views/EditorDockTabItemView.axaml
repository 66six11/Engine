<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Editor.Shell.ViewModels"
             x:Class="Editor.Shell.Views.EditorDockTabItemView"
             x:DataType="vm:EditorDockTabStripItemViewModel"
             IsHitTestVisible="{Binding IsRealTab}">
    <Border Classes.active="{Binding Tab.IsActive}"
            Classes.drag-source="{Binding Tab.IsDragSource}"
            Classes.placeholder="{Binding IsPlaceholder}"
            Classes="owned-dock-tab">
        <Grid ColumnDefinitions="Auto,*,Auto"
              ColumnSpacing="8">
            <Border Grid.Column="0"
                    Classes="owned-dock-tab-tag">
                <TextBlock Text="{Binding Tab.Tag}" />
            </Border>

            <StackPanel Grid.Column="1"
                        Classes="owned-dock-tab-title-stack">
                <TextBlock Classes="owned-dock-tab-title"
                           Text="{Binding Tab.Title}" />
                <TextBlock Classes="owned-dock-tab-detail"
                           Text="{Binding Tab.TitleDetail}" />
            </StackPanel>

            <Border Grid.Column="2"
                    Classes="owned-dock-tab-status">
                <TextBlock Text="{Binding Tab.StatusText}" />
            </Border>
        </Grid>
    </Border>
</UserControl>
