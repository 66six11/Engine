<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Editor.Shell.ViewModels"
             xmlns:views="using:Editor.Shell.Views"
             x:Class="Editor.Shell.Views.EditorDockWorkspaceView"
             x:DataType="vm:EditorDockWorkspaceViewModel">
    <Grid x:Name="DockRoot"
          Classes="owned-dock-root"
          ClipToBounds="True">
        <ContentControl x:Name="DockLayout"
                        Classes="owned-dock-node-host"
                        Content="{Binding RootNode}" />

        <Canvas x:Name="DockOverlay"
                Panel.ZIndex="20"
                IsHitTestVisible="False">
            <views:EditorDockDropGuideView DataContext="{Binding DragState}"
                                           Canvas.Left="{Binding GuideX}"
                                           Canvas.Top="{Binding GuideY}"
                                           Width="{Binding GuideWidth}"
                                           Height="{Binding GuideHeight}" />

            <Border Classes="owned-dock-drag-adorner"
                    IsVisible="{Binding DragState.IsActive}"
                    Canvas.Left="{Binding DragState.AdornerX}"
                    Canvas.Top="{Binding DragState.AdornerY}">
                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="8">
                    <Border Grid.Column="0"
                            Classes="owned-dock-drag-tag">
                        <TextBlock Text="{Binding DragState.Tag}" />
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock Classes="owned-dock-drag-title"
                                   Text="{Binding DragState.Title}" />
                        <TextBlock Classes="owned-dock-drag-subtitle"
                                   Text="{Binding DragState.OperationText}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Canvas>
    </Grid>
</UserControl>
