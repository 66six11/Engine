<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Editor.App"
             xmlns:local="using:Editor"
             xmlns:dockThemes="clr-namespace:Dock.Avalonia.Themes.Fluent;assembly=Dock.Avalonia.Themes.Fluent"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://Editor/UI/Styles/Tokens/DeepDarkColors.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
  
    <Application.Styles>
        <FluentTheme />
        <dockThemes:DockFluentTheme DensityStyle="Compact" CacheDocumentTabContent="True" />
        <StyleInclude Source="avares://Editor/UI/Styles/Shell/MainMenu.axaml" />
        <StyleInclude Source="avares://Editor/UI/Styles/Shell/Dock.axaml" />
    </Application.Styles>
</Application>
