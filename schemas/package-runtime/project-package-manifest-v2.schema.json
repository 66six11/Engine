{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.asharia.dev/package-runtime/project-package-manifest-v2.schema.json",
  "title": "Asharia Project Package Manifest v2",
  "description": "Portable project intent bound to one Engine Distribution family and API requirement.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "schemaVersion",
    "engine",
    "directPackages",
    "directFeatureSets",
    "packageOptions"
  ],
  "properties": {
    "schema": {
      "const": "com.asharia.project-packages"
    },
    "schemaVersion": {
      "const": 2
    },
    "engine": {
      "$ref": "#/$defs/engineRequirement"
    },
    "directPackages": {
      "type": "array",
      "items": {
        "$ref": "package-contract-common-v1.schema.json#/$defs/packageRequirement"
      }
    },
    "directFeatureSets": {
      "type": "array",
      "items": {
        "$ref": "package-contract-common-v1.schema.json#/$defs/packageRequirement"
      }
    },
    "packageOptions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/packageOptions"
      }
    }
  },
  "$defs": {
    "engineRequirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "distributionId",
        "apiVersion"
      ],
      "properties": {
        "distributionId": {
          "$ref": "package-contract-common-v1.schema.json#/$defs/packageId"
        },
        "apiVersion": {
          "$ref": "package-contract-common-v1.schema.json#/$defs/versionConstraint"
        }
      }
    },
    "packageOptions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packageId",
        "values"
      ],
      "properties": {
        "packageId": {
          "$ref": "package-contract-common-v1.schema.json#/$defs/packageId"
        },
        "values": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/optionValue"
          }
        }
      }
    },
    "optionValue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "value"
      ],
      "properties": {
        "id": {
          "$ref": "package-contract-common-v1.schema.json#/$defs/localId"
        },
        "value": {
          "oneOf": [
            {
              "type": "boolean"
            },
            {
              "type": "integer"
            },
            {
              "type": "string"
            }
          ]
        }
      }
    }
  }
}
