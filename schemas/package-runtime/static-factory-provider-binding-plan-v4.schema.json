{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.asharia.dev/package-runtime/static-factory-provider-binding-plan-v4.schema.json",
  "title": "Asharia Static Factory Provider Binding Plan v4",
  "description": "Canonical verified handoff from selected logical factories and contributions to selected static C++ provider v4 targets and entry points.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "schemaVersion",
    "inputs",
    "host",
    "providerApi",
    "providers",
    "integrity"
  ],
  "properties": {
    "schema": {
      "const": "com.asharia.static-factory-provider-binding-plan"
    },
    "schemaVersion": {
      "const": 4
    },
    "inputs": {
      "$ref": "#/$defs/inputs"
    },
    "host": {
      "$ref": "#/$defs/host"
    },
    "providerApi": {
      "const": "asharia-static-factory-provider-v4"
    },
    "providers": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/provider"
      }
    },
    "integrity": {
      "$ref": "#/$defs/integrity"
    }
  },
  "$defs": {
    "integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "digest"
      ],
      "properties": {
        "algorithm": {
          "const": "sha256"
        },
        "digest": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "effectiveSessionIntegrity",
        "sourceBuildPlanIntegrity",
        "hostActivationBlueprintIntegrity",
        "bindingDeclarationSetIntegrity"
      ],
      "properties": {
        "effectiveSessionIntegrity": {
          "$ref": "#/$defs/integrity"
        },
        "sourceBuildPlanIntegrity": {
          "$ref": "#/$defs/integrity"
        },
        "hostActivationBlueprintIntegrity": {
          "$ref": "#/$defs/integrity"
        },
        "bindingDeclarationSetIntegrity": {
          "$ref": "#/$defs/integrity"
        }
      }
    },
    "host": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "engineGenerationId",
        "hostKind",
        "targetPlatform"
      ],
      "properties": {
        "engineGenerationId": {
          "type": "string",
          "pattern": "^sha256-[0-9a-f]{64}$"
        },
        "hostKind": {
          "$ref": "package-contract-common-v1.schema.json#/$defs/hostKind"
        },
        "targetPlatform": {
          "$ref": "package-contract-common-v1.schema.json#/$defs/platformId"
        }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "type"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200,
          "pattern": "^[A-Za-z0-9_.+\\-]+$"
        },
        "type": {
          "const": "STATIC_LIBRARY"
        }
      }
    },
    "entryPoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "header",
        "function"
      ],
      "properties": {
        "header": {
          "type": "string",
          "minLength": 3,
          "maxLength": 240,
          "pattern": "^asharia/[A-Za-z0-9_+.\\-]+(?:/[A-Za-z0-9_+.\\-]+)*\\.(?:h|hh|hpp|hxx)$"
        },
        "function": {
          "type": "string",
          "minLength": 3,
          "maxLength": 240,
          "pattern": "^asharia::[A-Za-z_][A-Za-z0-9_]*(?:::[A-Za-z_][A-Za-z0-9_]*)+$"
        }
      }
    },
    "contribution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind"
      ],
      "properties": {
        "id": {
          "$ref": "package-contract-common-v1.schema.json#/$defs/packageId"
        },
        "kind": {
          "$ref": "package-contract-common-v1.schema.json#/$defs/packageId"
        }
      }
    },
    "factory": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "factoryId",
        "contributions"
      ],
      "properties": {
        "factoryId": {
          "$ref": "package-contract-common-v1.schema.json#/$defs/localId"
        },
        "contributions": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/contribution"
          }
        }
      }
    },
    "provider": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packageId",
        "packageVersion",
        "moduleId",
        "target",
        "entryPoint",
        "factories"
      ],
      "properties": {
        "packageId": {
          "$ref": "package-contract-common-v1.schema.json#/$defs/packageId"
        },
        "packageVersion": {
          "$ref": "package-contract-common-v1.schema.json#/$defs/semanticVersion"
        },
        "moduleId": {
          "$ref": "package-contract-common-v1.schema.json#/$defs/localId"
        },
        "target": {
          "$ref": "#/$defs/target"
        },
        "entryPoint": {
          "$ref": "#/$defs/entryPoint"
        },
        "factories": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/factory"
          }
        }
      }
    }
  }
}
