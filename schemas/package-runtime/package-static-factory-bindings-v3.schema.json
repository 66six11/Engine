{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.asharia.dev/package-runtime/package-static-factory-bindings-v3.schema.json",
  "title": "Asharia Package Static Factory Bindings v3",
  "description": "Exact source-build bindings from logical package factories to directly callable static C++ provider v3 entry points.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "schemaVersion",
    "package",
    "providerApi",
    "modules"
  ],
  "properties": {
    "schema": {
      "const": "com.asharia.package-static-factory-bindings"
    },
    "schemaVersion": {
      "const": 3
    },
    "package": {
      "$ref": "#/$defs/package"
    },
    "providerApi": {
      "const": "asharia-static-factory-provider-v3"
    },
    "modules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/module"
      }
    }
  },
  "$defs": {
    "package": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "version"
      ],
      "properties": {
        "id": {
          "$ref": "package-contract-common-v1.schema.json#/$defs/packageId"
        },
        "version": {
          "$ref": "package-contract-common-v1.schema.json#/$defs/semanticVersion"
        }
      }
    },
    "cmakeTargetName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "pattern": "^[A-Za-z0-9_.+\\-]+$"
    },
    "includeSpelling": {
      "type": "string",
      "minLength": 3,
      "maxLength": 240,
      "pattern": "^asharia/[A-Za-z0-9_+.\\-]+(?:/[A-Za-z0-9_+.\\-]+)*\\.(?:h|hh|hpp|hxx)$"
    },
    "qualifiedFunction": {
      "type": "string",
      "minLength": 3,
      "maxLength": 240,
      "pattern": "^asharia::[A-Za-z_][A-Za-z0-9_]*(?:::[A-Za-z_][A-Za-z0-9_]*)+$"
    },
    "entryPoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "header",
        "function"
      ],
      "properties": {
        "header": {
          "$ref": "#/$defs/includeSpelling"
        },
        "function": {
          "$ref": "#/$defs/qualifiedFunction"
        }
      }
    },
    "provider": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target",
        "entryPoint",
        "factoryIds"
      ],
      "properties": {
        "target": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "name",
            "type"
          ],
          "properties": {
            "name": {
              "$ref": "#/$defs/cmakeTargetName"
            },
            "type": {
              "const": "STATIC_LIBRARY"
            }
          }
        },
        "entryPoint": {
          "$ref": "#/$defs/entryPoint"
        },
        "factoryIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "package-contract-common-v1.schema.json#/$defs/localId"
          }
        }
      }
    },
    "noProviders": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "const": "no-providers"
        }
      }
    },
    "providerSet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "providers"
      ],
      "properties": {
        "kind": {
          "const": "provider-set"
        },
        "providers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/provider"
          }
        }
      }
    },
    "module": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "moduleId",
        "binding"
      ],
      "properties": {
        "moduleId": {
          "$ref": "package-contract-common-v1.schema.json#/$defs/localId"
        },
        "binding": {
          "oneOf": [
            {
              "$ref": "#/$defs/noProviders"
            },
            {
              "$ref": "#/$defs/providerSet"
            }
          ]
        }
      }
    }
  }
}
