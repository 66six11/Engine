{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.asharia.dev/package-runtime/project-package-sources-v1.schema.json",
  "title": "Asharia Project Package Sources v1",
  "description": "Portable project-owned package source selection without machine-local paths or package evidence.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "schemaVersion",
    "sources"
  ],
  "properties": {
    "schema": {
      "const": "com.asharia.project-package-sources"
    },
    "schemaVersion": {
      "const": 1
    },
    "sources": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "$ref": "#/$defs/projectEmbeddedSource"
          },
          {
            "$ref": "#/$defs/localSource"
          }
        ]
      }
    }
  },
  "$defs": {
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*\\\\).+$"
    },
    "projectEmbeddedSource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "relativePath"
      ],
      "properties": {
        "kind": {
          "const": "project-embedded"
        },
        "relativePath": {
          "$ref": "#/$defs/relativePath"
        }
      }
    },
    "localSource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "sourceId"
      ],
      "properties": {
        "kind": {
          "const": "local"
        },
        "sourceId": {
          "$ref": "package-contract-common-v1.schema.json#/$defs/packageId"
        }
      }
    }
  }
}
