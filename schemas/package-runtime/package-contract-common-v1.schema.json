{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.asharia.dev/package-runtime/package-contract-common-v1.schema.json",
  "title": "Asharia Package Contract Common Definitions v1",
  "description": "Shared identity and version constraint definitions for package-runtime author contracts.",
  "$defs": {
    "semanticVersion": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-(?:0|[1-9][0-9]*|[0-9A-Za-z-]*[A-Za-z-][0-9A-Za-z-]*)(?:\\.(?:0|[1-9][0-9]*|[0-9A-Za-z-]*[A-Za-z-][0-9A-Za-z-]*))*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
    },
    "packageId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:\\.[a-z](?:[a-z0-9-]*[a-z0-9])?){2,}$"
    },
    "localId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
    },
    "exactVersionConstraint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "version"
      ],
      "properties": {
        "kind": {
          "const": "exact"
        },
        "version": {
          "$ref": "#/$defs/semanticVersion"
        }
      }
    },
    "rangeVersionConstraint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "minimumInclusive",
        "maximumExclusive",
        "allowPrerelease"
      ],
      "properties": {
        "kind": {
          "const": "range"
        },
        "minimumInclusive": {
          "$ref": "#/$defs/semanticVersion"
        },
        "maximumExclusive": {
          "$ref": "#/$defs/semanticVersion"
        },
        "allowPrerelease": {
          "type": "boolean"
        }
      }
    },
    "versionConstraint": {
      "oneOf": [
        {
          "$ref": "#/$defs/exactVersionConstraint"
        },
        {
          "$ref": "#/$defs/rangeVersionConstraint"
        }
      ]
    },
    "packageRequirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "version"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/packageId"
        },
        "version": {
          "$ref": "#/$defs/versionConstraint"
        }
      }
    }
  }
}
