{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.asharia.dev/package-runtime/host-profile-v1.schema.json",
  "title": "Asharia Host Profile v1",
  "description": "Fixed host policy and invocation inputs for deterministic logical module and contribution filtering.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "schemaVersion",
    "hostKind",
    "targetPlatform",
    "requiredRoles",
    "allowedRoles",
    "allowedShippingClasses",
    "contributionFilter",
    "grantedCapabilities"
  ],
  "properties": {
    "schema": {
      "const": "com.asharia.host-profile"
    },
    "schemaVersion": {
      "const": 1
    },
    "hostKind": {
      "$ref": "package-contract-common-v1.schema.json#/$defs/hostKind"
    },
    "targetPlatform": {
      "allOf": [
        {
          "$ref": "package-contract-common-v1.schema.json#/$defs/platformId"
        },
        {
          "not": {
            "const": "com.asharia.platform.any"
          }
        }
      ]
    },
    "requiredRoles": {
      "$ref": "#/$defs/moduleRoleList"
    },
    "allowedRoles": {
      "$ref": "#/$defs/nonEmptyModuleRoleList"
    },
    "allowedShippingClasses": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "package-contract-common-v1.schema.json#/$defs/shippingClass"
      }
    },
    "contributionFilter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode"
      ],
      "properties": {
        "mode": {
          "enum": [
            "deny-all",
            "allow-compatible"
          ]
        }
      }
    },
    "grantedCapabilities": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "package-contract-common-v1.schema.json#/$defs/packageId"
      }
    }
  },
  "$defs": {
    "moduleRoleList": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "package-contract-common-v1.schema.json#/$defs/moduleRole"
      }
    },
    "nonEmptyModuleRoleList": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "package-contract-common-v1.schema.json#/$defs/moduleRole"
      }
    }
  }
}
